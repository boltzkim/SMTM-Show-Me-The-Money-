    "max_order_krw": 50000,
    "max_open_orders": 1,
    "max_position_ratio": "0.5",
    "daily_loss_limit_ratio": "0.03",
    "stale_data_seconds": 180
  },
  "repository": {
    "sqlite_path": "reports/sample_simulation.sqlite3"
  },
  "period_list": [
    {
      "start": "2025-01-01T00:00:00+09:00",
